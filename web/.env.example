# Copy to .env.local (dev), .env.staging, or .env.production and fill in.
# All NEXT_PUBLIC_* values are baked into the client bundle at build time.

# ── Firebase (audience sign-in only; the apiKey is a public project id) ──────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Realtime backend (lie-hard-server) ──────────────────────────────────────
# WebSocket URL. Leave unset for local dev (defaults to http://localhost:8080).
# Staging/prod: wss://<railway-url>
NEXT_PUBLIC_WS_URL=
# HTTP(S) base for the operator-login endpoint. Defaults to NEXT_PUBLIC_WS_URL.
# Staging/prod: https://<railway-url>
NEXT_PUBLIC_WS_HTTP_URL=
