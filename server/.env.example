# ── Server ───────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
# Comma-separated list of allowed browser origins (no trailing slash).
# Must exactly match this repo's frontend (the lie-hard-live Hosting origins).
ALLOWED_ORIGINS=http://localhost:3000,https://lie-hard-live.web.app,https://lie-hard-live.firebaseapp.com

# ── Operator auth ────────────────────────────────────────────────────────
# Secret used to sign operator JWTs. Generate a long random string.
JWT_SECRET=change-me-to-a-long-random-string
# bcrypt hash of the operator password (preferred). Generate with:
#   node -e "console.log(require('bcryptjs').hashSync('yourpassword',10))"
OPERATOR_PASSWORD_HASH=
# Dev-only fallback: plaintext operator password (used only if HASH is unset).
OPERATOR_PASSWORD=letmein
# Operator JWT lifetime.
OPERATOR_JWT_TTL=12h

# ── Firebase Admin (audience ID-token verification) ──────────────────────
# Base64-encoded service-account JSON. Decode at boot. Leave blank in local
# dev to accept the raw uid as the audience token (NODE_ENV != production only).
FIREBASE_SERVICE_ACCOUNT_B64=

# ── Persistence (both optional; server runs in-memory if unset) ───────────
# Redis connection string for crash-recovery snapshots.
REDIS_URL=
# How often (ms) to snapshot the in-memory game state.
SNAPSHOT_INTERVAL_MS=5000
